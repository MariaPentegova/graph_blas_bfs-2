#include <stdio.h>
#include <stdlib.h>
#include <assert.h>
#include "classic_bfs.h"

void test_line_graph() {
    printf("\n[TEST 1] BFS on line graph (0-1-2-3)\n");
    
    // Graph: 0--1--2--3
    int row_ptr[] = {0, 1, 3, 5, 6};
    int col_idx[] = {1, 0, 2, 1, 3, 2};
    int n = 4;
    
    BFSResult* result = classic_bfs(n, row_ptr, col_idx, 0);
    
    // Check parent relationships
    assert(result->parent[0] == 0);
    assert(result->parent[1] == 0);
    assert(result->parent[2] == 1);
    assert(result->parent[3] == 2);
    
    // Check levels
    assert(result->level[0] == 0);
    assert(result->level[1] == 1);
    assert(result->level[2] == 2);
    assert(result->level[3] == 3);
    
    // Check visited count
    assert(result->visited_count == 4);
    
    free_bfs_result(result);
    printf(" Test passed\n");
}

void test_disconnected_graph() {
    printf("\n[TEST 2] BFS on disconnected graph\n");
    
    // Graph: 0-1, 2 isolated, 3-4
    int row_ptr[] = {0, 1, 2, 2, 3, 3};
    int col_idx[] = {1, 0, 3, 4};
    int n = 5;
    
    BFSResult* result = classic_bfs(n, row_ptr, col_idx, 0);
    
    // Reachable from source 0
    assert(result->parent[0] == 0);
    assert(result->parent[1] == 0);
    assert(result->parent[2] == -1);  // isolated
    assert(result->parent[3] == -1);  // not reachable
    assert(result->parent[4] == -1);  // not reachable
    
    assert(result->level[0] == 0);
    assert(result->level[1] == 1);
    assert(result->level[2] == -1);
    assert(result->level[3] == -1);
    assert(result->level[4] == -1);
    
    assert(result->visited_count == 2);
    
    free_bfs_result(result);
    printf(" Test passed\n");
}

void test_single_node() {
    printf("\n[TEST 3] BFS on single node\n");
    
    int row_ptr[] = {0, 0};
    int col_idx[] = {};
    int n = 1;
    
    BFSResult* result = classic_bfs(n, row_ptr, col_idx, 0);
    
    assert(result->parent[0] == 0);
    assert(result->level[0] == 0);
    assert(result->visited_count == 1);
    
    free_bfs_result(result);
    printf(" Test passed\n");
}

void test_multisource() {
    printf("\n[TEST 4] Multi-source BFS\n");
    
    // Graph: 0-1, 2-3, 4 isolated
    int row_ptr[] = {0, 1, 2, 3, 4, 4};
    int col_idx[] = {1, 0, 3, 2};
    int n = 5;
    int sources[] = {0, 2};
    
    BFSResult result;
    classic_bfs_multisource(n, row_ptr, col_idx, sources, 2, &result);
    
    assert(result.parent[0] == 0);
    assert(result.parent[1] == 0);
    assert(result.parent[2] == 2);
    assert(result.parent[3] == 2);
    assert(result.parent[4] == -1);
    
    assert(result.level[0] == 0);
    assert(result.level[1] == 1);
    assert(result.level[2] == 0);
    assert(result.level[3] == 1);
    assert(result.level[4] == -1);
    
    assert(result.visited_count == 4);
    
    free_bfs_result(&result);
    printf(" Test passed\n");
}

int main() {
    printf("     Classic BFS Unit Tests            \n");
    
    test_line_graph();
    test_disconnected_graph();
    test_single_node();
    test_multisource();
    
    printf("     All Classic BFS tests PASSED!     \n");
    
    return 0;
}
